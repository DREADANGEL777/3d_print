rules_version = '2';

// Вставте ці правила у консолі Firebase:
// Firestore Database → Rules → замінити вміст → Publish
//
// Логіка: будь-хто може СТВОРИТИ заявку (створення з валідацією полів),
// але ніхто не може читати, змінювати чи видаляти їх з сайту.
// Ви переглядаєте заявки лише через консоль Firebase.
service cloud.firestore {
  match /databases/{database}/documents {
    match /leads/{leadId} {
      allow create: if request.resource.data.keys().hasOnly(['name', 'phone', 'message', 'createdAt'])
                    && request.resource.data.name is string
                    && request.resource.data.name.size() > 0
                    && request.resource.data.name.size() <= 100
                    && request.resource.data.phone is string
                    && request.resource.data.phone.size() >= 7
                    && request.resource.data.phone.size() <= 30
                    && request.resource.data.message is string
                    && request.resource.data.message.size() <= 2000
                    && request.resource.data.createdAt == request.time;
      allow read, update, delete: if false;
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
